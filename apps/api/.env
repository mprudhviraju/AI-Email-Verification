DATABASE_URL="postgresql://postgres@localhost:5432/email_verification"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="ai-email-verifier-super-secret-jwt-key-2026"
PORT=4001
# C2: Comma-separated source IPs for outbound SMTP connections.
# Empty = noop mode (OS picks the outbound interface) — safe for local dev.
# Production example: SMTP_SOURCE_IPS=203.0.113.10,203.0.113.11
SMTP_SOURCE_IPS=
# F1: SOCKS5 proxies for providers that block AWS IPs (Yahoo TSS, Outlook Spamhaus PBL).
# Takes precedence over SMTP_SOURCE_IPS when both are set.
# Empty = noop mode (falls through to SMTP_SOURCE_IPS or OS default) — safe for local dev.
# Production example: SMTP_PROXY_LIST=socks5://user:pass@host1:1080,socks5://user:pass@host2:1080
SMTP_PROXY_LIST=
# F2: Comma-separated CORS origins. Add Amplify/production domain when deploying.
# Example: CORS_ORIGINS=http://localhost:5173,https://main.d1abc.amplifyapp.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
